# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Environment variables — NEVER push this
.env
.env.local
.env.production

# Django
db.sqlite3
staticfiles/

# Media — allow small files, exclude huge brochure PNGs and PDFs
media/brochure/
media/brochure_pdf/

# Static images — block PNG/JPG originals (pre-commit hook converts them to WebP)
# Exception: chatbot-icon.png and favicon files are allowed
static/images/*.png
static/images/*.jpg
static/images/*.jpeg
!static/images/chatbot-icon.png
!static/images/favicon*.png

# Node / Tailwind build
node_modules/
package-lock.json

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Logs
*.log
